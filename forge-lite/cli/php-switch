#!/usr/bin/env bash
# forge-lite CLI: php-switch — Switch default PHP CLI + FPM version
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# When installed to /usr/local/bin, FORGE_LITE_DIR may not be available
# Source common.sh if available, otherwise define minimal helpers
if [[ -f "${SCRIPT_DIR}/../lib/common.sh" ]]; then
    export FORGE_LITE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
    source "${FORGE_LITE_DIR}/lib/common.sh"
    source "${FORGE_LITE_DIR}/lib/validation.sh"
else
    # Minimal fallback for installed CLI
    log_info()  { echo "[INFO]  $*" >&2; }
    log_ok()    { echo "[OK]    $*" >&2; }
    log_error() { echo "[ERROR] $*" >&2; }
    die() { log_error "$@"; exit 1; }
    validate_php_version() {
        local v="$1"
        [[ "$v" =~ ^8\.[1-4]$ ]] || die "Unsupported PHP version: $v"
    }
fi

[[ $EUID -eq 0 ]] || die "This script must be run as root (use sudo)."

if [[ $# -lt 1 ]]; then
    echo "Usage: php-switch <version>"
    echo "  Switches the default PHP CLI and FPM version."
    echo "  Supported versions: 8.1, 8.2, 8.3, 8.4"
    exit 1
fi

VERSION="$1"
validate_php_version "$VERSION"

# Verify the target PHP version is installed
if ! command -v "php${VERSION}" &>/dev/null; then
    die "PHP ${VERSION} is not installed."
fi

log_info "Switching to PHP ${VERSION}..."

# Update alternatives for CLI
update-alternatives --set php "/usr/bin/php${VERSION}"
update-alternatives --set phar "/usr/bin/phar${VERSION}" 2>/dev/null || true
update-alternatives --set phar.phar "/usr/bin/phar.phar${VERSION}" 2>/dev/null || true

# Disable all FPM services, enable only the target
for v in 8.1 8.2 8.3 8.4; do
    if systemctl is-active --quiet "php${v}-fpm" 2>/dev/null; then
        if [[ "$v" != "$VERSION" ]]; then
            systemctl stop "php${v}-fpm"
            systemctl disable "php${v}-fpm" 2>/dev/null || true
            log_info "Disabled PHP ${v} FPM"
        fi
    fi
done

systemctl enable "php${VERSION}-fpm" 2>/dev/null || true
systemctl restart "php${VERSION}-fpm"

# Reload nginx to pick up any socket changes
if systemctl is-active --quiet nginx; then
    systemctl reload nginx
fi

log_ok "Switched to PHP ${VERSION} (CLI: $(php -v | head -1))"
