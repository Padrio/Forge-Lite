#!/usr/bin/env bash
# forge-lite CLI — Unified entry point for forge-lite server management
set -euo pipefail

# Resolve FORGE_LITE_DIR from script location, fallback to /opt/forge-lite
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -d "${SCRIPT_DIR}/../server" ]]; then
    FORGE_LITE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
else
    FORGE_LITE_DIR="/opt/forge-lite"
fi

# Source lib/common.sh if available
if [[ -f "${FORGE_LITE_DIR}/lib/common.sh" ]]; then
    source "${FORGE_LITE_DIR}/lib/common.sh"
else
    # Minimal fallback for installed CLI
    log_info()  { echo "[INFO]  $*" >&2; }
    log_ok()    { echo "[OK]    $*" >&2; }
    log_warn()  { echo "[WARN]  $*" >&2; }
    log_error() { echo "[ERROR] $*" >&2; }
    die() { log_error "$@"; exit 1; }
    sed_escape_value() {
        printf '%s' "$1" | sed -e 's/[&/\|]/\\&/g'
    }
    get_server_ipv4() {
        local ip
        ip="$(curl -4 -s --max-time 5 ifconfig.me 2>/dev/null)" || true
        if [[ -z "$ip" ]]; then
            ip="$(ip -4 addr show scope global 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -1)" || true
        fi
        printf '%s' "${ip:-}"
    }
    get_server_ipv6() {
        local ip
        ip="$(curl -6 -s --max-time 5 ifconfig.me 2>/dev/null)" || true
        if [[ -z "$ip" ]]; then
            ip="$(ip -6 addr show scope global 2>/dev/null | awk '/inet6 / {print $2}' | cut -d/ -f1 | head -1)" || true
        fi
        printf '%s' "${ip:-}"
    }
    has_ipv6() {
        local ipv6
        ipv6="$(get_server_ipv6)"
        [[ -n "$ipv6" ]]
    }
fi

[[ $EUID -eq 0 ]] || die "This script must be run as root (use sudo)."

SITE_CONFIG_DIR="/etc/forge-lite"

# Version
FORGE_LITE_VERSION=""
if [[ -f "${FORGE_LITE_DIR}/VERSION" ]]; then
    FORGE_LITE_VERSION=$(cat "${FORGE_LITE_DIR}/VERSION")
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

# Upsert KEY=VALUE in a config file (grep -F for safety, sed-escaped value)
config_upsert() {
    local file="$1" key="$2" value="$3"
    local escaped_val
    escaped_val=$(sed_escape_value "$value")
    if grep -qF "${key}=" "$file" 2>/dev/null && grep -q "^${key}=" "$file" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${escaped_val}|" "$file"
    else
        echo "${key}=${value}" >> "$file"
    fi
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
usage() {
    cat <<'USAGE'
Usage: forge-lite <command> [args]

Commands:
    site add [flags]                  Add a new site
    site remove <domain> [flags]      Remove a site
    site list                         List all configured sites

    deploy <domain> [flags]           Deploy a site
    deploy setup <domain> [flags]     Configure repo-based deployments
    rollback <domain>                 Rollback to previous release
    status                            Show service status and site overview

    runner setup [flags]              Add a self-hosted GitHub Actions runner
    runner remove --name=N [flags]    Remove a specific runner
    runner status                     Show all runners status
    runner list                       Quick list of all runners

    db <subcommand> [args]            Database management
    env <subcommand> [args]           .env variable management
    ssl <subcommand> [args]           SSL certificate management
    php <version>                     Switch default PHP version
    provision [flags]                 Provision the server
    update                            Reinstall CLI tools and completions
    --version                         Show forge-lite version

Run 'forge-lite <command> --help' for command-specific help.
USAGE
    exit 0
}

# ---------------------------------------------------------------------------
# site commands
# ---------------------------------------------------------------------------
cmd_site() {
    [[ $# -ge 1 ]] || die "Usage: forge-lite site <add|remove|list> [args]"
    local sub="$1"; shift

    case "$sub" in
        add)
            exec "${FORGE_LITE_DIR}/sites/add-site.sh" "$@"
            ;;
        remove)
            exec "${FORGE_LITE_DIR}/sites/remove-site.sh" "$@"
            ;;
        list)
            cmd_site_list
            ;;
        -h|--help)
            echo "Usage: forge-lite site <add|remove|list> [args]"
            exit 0
            ;;
        *)
            die "Unknown site command: $sub. Use add, remove, or list."
            ;;
    esac
}

cmd_site_list() {
    if [[ ! -d "$SITE_CONFIG_DIR" ]] || ! ls "${SITE_CONFIG_DIR}"/*.conf &>/dev/null; then
        log_info "No sites configured."
        return 0
    fi

    printf "%-30s %-6s %-8s %-8s %-4s\n" "DOMAIN" "PHP" "HORIZON" "WORKERS" "SSL"
    printf "%-30s %-6s %-8s %-8s %-4s\n" "------" "---" "-------" "-------" "---"

    for conf in "${SITE_CONFIG_DIR}"/*.conf; do
        # Source in subshell to prevent variable pollution
        (
            # shellcheck disable=SC1090
            source "$conf"
            local horizon_display="-"
            local workers_display="${QUEUE_WORKERS:-0}"
            if [[ "${ENABLE_HORIZON:-false}" == "true" ]]; then
                horizon_display="yes"
                workers_display="-"
            fi
            printf "%-30s %-6s %-8s %-8s %-4s\n" \
                "${DOMAIN:-unknown}" \
                "${PHP_VERSION:-?}" \
                "$horizon_display" \
                "$workers_display" \
                "${SSL:-no}"
        )
    done
}

# ---------------------------------------------------------------------------
# deploy commands
# ---------------------------------------------------------------------------
cmd_deploy() {
    [[ $# -ge 1 ]] || die "Usage: forge-lite deploy <domain|setup> [flags]"

    # Check if first arg is the "setup" subcommand
    if [[ "$1" == "setup" ]]; then
        shift
        cmd_deploy_setup "$@"
        return
    fi

    local domain="$1"; shift
    local args=("$@")

    # Check if --artifact or --repo was explicitly passed
    local has_artifact=false has_repo=false
    for arg in "${args[@]+"${args[@]}"}"; do
        case "$arg" in
            --artifact=*) has_artifact=true ;;
            --repo=*)     has_repo=true ;;
        esac
    done

    # Auto-inject repo config if neither --artifact nor --repo was passed
    if [[ "$has_artifact" == false && "$has_repo" == false ]]; then
        local site_conf="${SITE_CONFIG_DIR}/${domain}.conf"
        if [[ -f "$site_conf" ]]; then
            # Read config in subshell to prevent variable pollution
            local deploy_repo deploy_branch
            deploy_repo=$(grep "^DEPLOY_REPO=" "$site_conf" 2>/dev/null | head -1 | cut -d= -f2-) || true
            deploy_branch=$(grep "^DEPLOY_BRANCH=" "$site_conf" 2>/dev/null | head -1 | cut -d= -f2-) || true

            if [[ -n "$deploy_repo" ]]; then
                args+=("--repo=${deploy_repo}")
                if [[ -n "$deploy_branch" ]]; then
                    args+=("--branch=${deploy_branch}")
                fi
                log_info "Using configured repo: ${deploy_repo} (branch: ${deploy_branch:-default})"
            fi
        fi
    fi

    exec "${FORGE_LITE_DIR}/deploy/deploy.sh" "$domain" "${args[@]+"${args[@]}"}"
}

cmd_deploy_setup() {
    local domain="" repo="" branch="main"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --repo=*)   repo="${1#*=}"; shift ;;
            --branch=*) branch="${1#*=}"; shift ;;
            -h|--help)
                echo "Usage: forge-lite deploy setup <domain> --repo=URL [--branch=BRANCH]"
                exit 0
                ;;
            -*)         die "Unknown flag: $1" ;;
            *)          domain="$1"; shift ;;
        esac
    done

    [[ -n "$domain" ]] || die "Domain required. Usage: forge-lite deploy setup <domain> --repo=URL"
    [[ -n "$repo" ]]   || die "Repository URL required. Use --repo=URL"

    local site_conf="${SITE_CONFIG_DIR}/${domain}.conf"
    [[ -f "$site_conf" ]] || die "Site config not found: ${site_conf}. Is '${domain}' a valid site?"

    config_upsert "$site_conf" "DEPLOY_REPO" "$repo"
    config_upsert "$site_conf" "DEPLOY_BRANCH" "$branch"

    log_ok "Deploy config saved for ${domain}"
    log_info "  Repo:   ${repo}"
    log_info "  Branch: ${branch}"
    log_info "Run 'forge-lite deploy ${domain}' to deploy."
}

# ---------------------------------------------------------------------------
# runner commands
# ---------------------------------------------------------------------------
cmd_runner() {
    [[ $# -ge 1 ]] || die "Usage: forge-lite runner <setup|remove|status|list> [args]"
    local sub="$1"; shift

    source "${FORGE_LITE_DIR}/server/modules/github-runner.sh"

    case "$sub" in
        setup)
            provision_github_runner "$@"
            ;;
        remove)
            remove_github_runner "$@"
            ;;
        status)
            status_github_runner
            ;;
        list)
            list_github_runners
            ;;
        -h|--help)
            cat <<'USAGE'
Usage: forge-lite runner <command> [args]

Commands:
    setup   --repo=URL --token=TOKEN [--name=NAME] [--labels=LABELS]
    remove  --name=NAME --token=TOKEN
    status  Show detailed status of all runners
    list    Quick tabular overview of all runners
USAGE
            exit 0
            ;;
        *)
            die "Unknown runner command: $sub. Use setup, remove, status, or list."
            ;;
    esac
}

# ---------------------------------------------------------------------------
# update command
# ---------------------------------------------------------------------------
cmd_update() {
    local cli_dir="${FORGE_LITE_DIR}/cli"
    local tools=(php-switch forge-lite-db forge-lite-ssl forge-lite-env forge-lite)

    log_info "Reinstalling CLI tools from ${cli_dir} ..."
    for tool in "${tools[@]}"; do
        install -m 755 "${cli_dir}/${tool}" /usr/local/bin/
        log_ok "Installed ${tool}"
    done

    local completion_src="${cli_dir}/completions/forge-lite.bash"
    if [[ -d /etc/bash_completion.d ]]; then
        install -m 644 "$completion_src" /etc/bash_completion.d/forge-lite
        log_ok "Installed bash completion"
    else
        log_warn "Skipped bash completion (/etc/bash_completion.d not found)"
    fi

    log_ok "forge-lite update complete — ${#tools[@]} tools reinstalled."
}

# ---------------------------------------------------------------------------
# status command
# ---------------------------------------------------------------------------
cmd_status() {
    echo "=== forge-lite Status ==="
    [[ -n "$FORGE_LITE_VERSION" ]] && echo "Version: ${FORGE_LITE_VERSION}"
    echo ""

    echo "--- Services ---"
    local services=(nginx mariadb redis-server supervisor)
    # Add active PHP-FPM services
    for v in 8.1 8.2 8.3 8.4; do
        if systemctl list-unit-files "php${v}-fpm.service" &>/dev/null 2>&1; then
            services+=("php${v}-fpm")
        fi
    done

    for svc in "${services[@]}"; do
        if systemctl is-active --quiet "$svc" 2>/dev/null; then
            printf "  %-20s %s\n" "$svc" "running"
        elif systemctl list-unit-files "${svc}.service" 2>/dev/null | grep -q "$svc"; then
            printf "  %-20s %s\n" "$svc" "stopped"
        fi
    done

    echo ""
    echo "--- Network ---"
    local ipv4 ipv6 dual_stack="no"
    ipv4=$(get_server_ipv4 2>/dev/null) || ipv4=""
    ipv6=$(get_server_ipv6 2>/dev/null) || ipv6=""
    [[ -n "$ipv4" && -n "$ipv6" ]] && dual_stack="yes"
    printf "  %-14s %s\n" "IPv4:" "${ipv4:-not detected}"
    printf "  %-14s %s\n" "IPv6:" "${ipv6:-not detected}"
    printf "  %-14s %s\n" "Dual-Stack:" "$dual_stack"

    echo ""
    echo "--- Disk Usage ---"
    df -h / /home 2>/dev/null | awk 'NR==1 || !/^Filesystem/' | head -3

    echo ""
    echo "--- Sites ---"
    if [[ -d "$SITE_CONFIG_DIR" ]] && ls "${SITE_CONFIG_DIR}"/*.conf &>/dev/null 2>&1; then
        printf "  %-30s %-6s %-4s\n" "DOMAIN" "PHP" "SSL"
        for conf in "${SITE_CONFIG_DIR}"/*.conf; do
            (
                # shellcheck disable=SC1090
                source "$conf"
                printf "  %-30s %-6s %-4s\n" \
                    "${DOMAIN:-unknown}" \
                    "${PHP_VERSION:-?}" \
                    "${SSL:-no}"
            )
        done
    else
        echo "  No sites configured."
    fi
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
[[ $# -ge 1 ]] || usage

case "$1" in
    site)
        shift; cmd_site "$@" ;;
    deploy)
        shift; cmd_deploy "$@" ;;
    rollback)
        shift
        exec "${FORGE_LITE_DIR}/deploy/rollback.sh" "$@"
        ;;
    runner)
        shift; cmd_runner "$@" ;;
    db)
        shift
        exec forge-lite-db "$@"
        ;;
    env)
        shift
        exec forge-lite-env "$@"
        ;;
    ssl)
        shift
        exec forge-lite-ssl "$@"
        ;;
    php)
        shift
        exec php-switch "$@"
        ;;
    provision)
        shift
        exec "${FORGE_LITE_DIR}/server/provision.sh" "$@"
        ;;
    update)
        cmd_update
        ;;
    status)
        cmd_status
        ;;
    --version|-v)
        if [[ -n "$FORGE_LITE_VERSION" ]]; then
            echo "forge-lite ${FORGE_LITE_VERSION}"
        else
            echo "forge-lite (version unknown)"
        fi
        ;;
    -h|--help)
        usage
        ;;
    *)
        die "Unknown command: $1. Run 'forge-lite --help' for usage."
        ;;
esac
