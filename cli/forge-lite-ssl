#!/usr/bin/env bash
# forge-lite CLI: forge-lite-ssl — SSL certificate management
set -euo pipefail

# Source lib/common.sh if available
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "${SCRIPT_DIR}/../lib/common.sh" ]]; then
    export FORGE_LITE_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
    source "${FORGE_LITE_DIR}/lib/common.sh"
else
    # Minimal fallback for installed CLI
    log_info()  { echo "[INFO]  $*" >&2; }
    log_ok()    { echo "[OK]    $*" >&2; }
    log_warn()  { echo "[WARN]  $*" >&2; }
    log_error() { echo "[ERROR] $*" >&2; }
    die() { log_error "$@"; exit 1; }
    get_server_ipv4() {
        local ip
        ip="$(curl -4 -s --max-time 5 ifconfig.me 2>/dev/null)" || true
        if [[ -z "$ip" ]]; then
            ip="$(ip -4 addr show scope global 2>/dev/null | awk '/inet / {print $2}' | cut -d/ -f1 | head -1)" || true
        fi
        printf '%s' "${ip:-}"
    }
    get_server_ipv6() {
        local ip
        ip="$(curl -6 -s --max-time 5 ifconfig.me 2>/dev/null)" || true
        if [[ -z "$ip" ]]; then
            ip="$(ip -6 addr show scope global 2>/dev/null | awk '/inet6 / {print $2}' | cut -d/ -f1 | head -1)" || true
        fi
        printf '%s' "${ip:-}"
    }
    has_ipv6() {
        local ipv6
        ipv6="$(get_server_ipv6)"
        [[ -n "$ipv6" ]]
    }
fi

[[ $EUID -eq 0 ]] || die "This script must be run as root (use sudo)."

usage() {
    cat <<'USAGE'
Usage: forge-lite-ssl <command> <domain>

Commands:
    issue <domain>    Obtain SSL certificate via Let's Encrypt
    remove <domain>   Remove SSL and revert to HTTP
    renew <domain>    Force-renew certificate for domain
    status <domain>   Show certificate status and expiry
USAGE
    exit 0
}

FORGE_LITE_TEMPLATES="/opt/forge-lite/server/config/templates"
# Try to find templates relative to script location as fallback
if [[ -d "${SCRIPT_DIR}/../server/config/templates" ]]; then
    FORGE_LITE_TEMPLATES="${SCRIPT_DIR}/../server/config/templates"
fi

cmd_issue() {
    local domain="$1"
    [[ -n "$domain" ]] || die "Domain required."

    # Check DNS resolution (A + AAAA records)
    local server_ipv4 server_ipv6 domain_ipv4 domain_ipv6
    server_ipv4=$(get_server_ipv4 2>/dev/null) || server_ipv4=""
    server_ipv6=$(get_server_ipv6 2>/dev/null) || server_ipv6=""
    domain_ipv4=$(dig +short "$domain" A 2>/dev/null | head -1) || domain_ipv4=""
    domain_ipv6=$(dig +short "$domain" AAAA 2>/dev/null | head -1) || domain_ipv6=""

    # Check A record
    if [[ -n "$server_ipv4" && -n "$domain_ipv4" && "$server_ipv4" != "$domain_ipv4" ]]; then
        log_warn "A record for '${domain}' points to ${domain_ipv4}, but this server is ${server_ipv4}"
        log_warn "Certbot will likely fail. Point your A record to ${server_ipv4} first."
    elif [[ -z "$domain_ipv4" ]]; then
        log_warn "No A record found for '${domain}'. Certbot will likely fail."
        [[ -n "$server_ipv4" ]] && log_warn "Point your A record to ${server_ipv4}"
    fi

    # Check AAAA record (only if server has IPv6)
    if [[ -n "$server_ipv6" ]]; then
        if [[ -n "$domain_ipv6" && "$server_ipv6" != "$domain_ipv6" ]]; then
            log_warn "AAAA record for '${domain}' points to ${domain_ipv6}, but this server is ${server_ipv6}"
        elif [[ -z "$domain_ipv6" ]]; then
            log_info "No AAAA record for '${domain}'. IPv6 visitors won't reach this site."
            log_info "Add an AAAA record pointing to ${server_ipv6} for full Dual-Stack."
        fi
    fi

    # Issue certificate
    log_info "Requesting SSL certificate for ${domain}..."
    certbot certonly --nginx \
        -d "$domain" \
        --non-interactive \
        --agree-tos \
        --register-unsafely-without-email

    # Verify certificate was obtained
    if [[ ! -f "/etc/letsencrypt/live/${domain}/fullchain.pem" ]]; then
        die "SSL certificate was not obtained. Verify DNS and try again."
    fi

    # Switch nginx vhost to SSL variant if site config exists
    local site_conf="/etc/forge-lite/${domain}.conf"
    if [[ -f "$site_conf" ]]; then
        # shellcheck disable=SC1090
        source "$site_conf"
        local php_version="${PHP_VERSION:-8.3}"
        local fpm_socket="${FPM_SOCKET:-/var/run/php/php${php_version}-${domain}-fpm.sock}"

        [[ -f "${FORGE_LITE_TEMPLATES}/nginx/vhost-ssl.conf" ]] || \
            die "SSL vhost template not found: ${FORGE_LITE_TEMPLATES}/nginx/vhost-ssl.conf"

        local tmp_vhost
        tmp_vhost="$(mktemp)"
        sed -e "s|{{DOMAIN}}|${domain}|g" \
            -e "s|{{FPM_SOCKET}}|${fpm_socket}|g" \
            "${FORGE_LITE_TEMPLATES}/nginx/vhost-ssl.conf" \
            > "$tmp_vhost"
        mv "$tmp_vhost" "/etc/nginx/sites-available/${domain}.conf"
        chmod 644 "/etc/nginx/sites-available/${domain}.conf"

        nginx -t && systemctl reload nginx
        log_ok "NGINX vhost updated to SSL for ${domain}"

        # Update site config — replace existing SSL value
        if grep -q "^SSL=" "$site_conf" 2>/dev/null; then
            sed -i "s|^SSL=.*|SSL=true|" "$site_conf"
        else
            echo "SSL=true" >> "$site_conf"
        fi

        # Update APP_URL in .env (escape dots for grep/sed regex safety)
        local site_dir="${SITE_DIR:-/home/deployer/sites/${domain}}"
        local env_file="${site_dir}/shared/.env"
        local escaped_domain="${domain//./\\.}"
        if [[ -f "$env_file" ]]; then
            if grep -q "^APP_URL=http://${escaped_domain}" "$env_file" 2>/dev/null; then
                sed -i "s|^APP_URL=http://${escaped_domain}|APP_URL=https://${domain}|" "$env_file"
                log_ok "Updated APP_URL to https://${domain}"
            fi
        fi
    fi

    log_ok "SSL certificate issued for ${domain}"
}

cmd_remove() {
    local domain="$1"
    [[ -n "$domain" ]] || die "Domain required."

    local site_conf="/etc/forge-lite/${domain}.conf"
    [[ -f "$site_conf" ]] || die "Site config not found: ${site_conf}"

    # shellcheck disable=SC1090
    source "$site_conf"

    if [[ "${SSL:-false}" != "true" ]]; then
        log_info "SSL is not enabled for ${domain}. Nothing to do."
        return 0
    fi

    log_info "Removing SSL for ${domain}..."
    log_warn "HSTS was active — browsers may enforce HTTPS for up to 1 year for returning visitors."

    # Restore HTTP-only vhost
    local php_version="${PHP_VERSION:-8.3}"
    local fpm_socket="${FPM_SOCKET:-/var/run/php/php${php_version}-${domain}-fpm.sock}"

    [[ -f "${FORGE_LITE_TEMPLATES}/nginx/vhost.conf" ]] || \
        die "HTTP vhost template not found: ${FORGE_LITE_TEMPLATES}/nginx/vhost.conf"

    local tmp_vhost
    tmp_vhost="$(mktemp)"
    sed -e "s|{{DOMAIN}}|${domain}|g" \
        -e "s|{{FPM_SOCKET}}|${fpm_socket}|g" \
        "${FORGE_LITE_TEMPLATES}/nginx/vhost.conf" \
        > "$tmp_vhost"
    mv "$tmp_vhost" "/etc/nginx/sites-available/${domain}.conf"
    chmod 644 "/etc/nginx/sites-available/${domain}.conf"

    nginx -t && systemctl reload nginx
    log_ok "NGINX vhost reverted to HTTP for ${domain}"

    # Update site config
    if grep -q "^SSL=" "$site_conf" 2>/dev/null; then
        sed -i "s|^SSL=.*|SSL=false|" "$site_conf"
    fi

    # Update APP_URL in .env (escape dots for grep/sed regex safety)
    local site_dir="${SITE_DIR:-/home/deployer/sites/${domain}}"
    local env_file="${site_dir}/shared/.env"
    local escaped_domain="${domain//./\\.}"
    if [[ -f "$env_file" ]]; then
        if grep -q "^APP_URL=https://${escaped_domain}" "$env_file" 2>/dev/null; then
            sed -i "s|^APP_URL=https://${escaped_domain}|APP_URL=http://${domain}|" "$env_file"
            log_ok "Reverted APP_URL to http://${domain}"
        fi
    fi

    # Remove Let's Encrypt certificate
    if [[ -d "/etc/letsencrypt/live/${domain}" ]]; then
        certbot delete --cert-name "$domain" --non-interactive 2>/dev/null || \
            log_warn "Could not remove certificate via certbot — clean up manually if needed"
    fi

    log_ok "SSL removed for ${domain}"
}

cmd_renew() {
    local domain="$1"
    [[ -n "$domain" ]] || die "Domain required."

    log_info "Renewing SSL certificate for ${domain}..."
    certbot renew --cert-name "$domain" --force-renewal
    systemctl reload nginx 2>/dev/null || true

    log_ok "SSL certificate renewed for ${domain}"
}

cmd_status() {
    local domain="$1"
    [[ -n "$domain" ]] || die "Domain required."

    local cert_dir="/etc/letsencrypt/live/${domain}"
    if [[ ! -d "$cert_dir" ]]; then
        log_error "No certificate found for ${domain}"
        exit 1
    fi

    echo "Certificate: ${cert_dir}/fullchain.pem"
    echo ""
    openssl x509 -in "${cert_dir}/fullchain.pem" -noout \
        -subject -issuer -dates -fingerprint
}

# Main dispatch
[[ $# -ge 1 ]] || usage

case "$1" in
    issue)  cmd_issue "${2:-}" ;;
    remove) cmd_remove "${2:-}" ;;
    renew)  cmd_renew "${2:-}" ;;
    status) cmd_status "${2:-}" ;;
    -h|--help) usage ;;
    *)      die "Unknown command: $1. Run with --help for usage." ;;
esac
